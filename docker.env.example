# Docker Environment Configuration
# Copy this file to .env and modify values as needed

# Application Configuration
NODE_ENV=production
REACT_APP_API_URL=https://aisa.se.jku.at/api

# Auth0 (required for `docker compose build` — copy to `.env` in this directory)
REACT_APP_AUTH0_DOMAIN=dev-hc5xq20mp6n2hmi7.us.auth0.com
REACT_APP_AUTH0_CLIENT_ID=0yINZRthcFTmqFTfUVSaEIgV7sVN2Y8R
# Optional API identifier for access tokens
REACT_APP_AUTH0_AUDIENCE=https://aisa-backend

# Docker Configuration
COMPOSE_PROJECT_NAME=aisa-frontend
DOCKER_BUILDKIT=1

# Port Configuration
FRONTEND_PORT=3000
BACKEND_PORT=8001

# Network Configuration
NETWORK_NAME=aisa-network

# Volume Configuration
DATA_VOLUME=aisa-data
